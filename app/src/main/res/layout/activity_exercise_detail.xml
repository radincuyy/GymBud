<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:id="@+id/clExerciseDetailRoot">

        <!-- Screen Title -->
        <TextView
            android:id="@+id/tvDetailTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/exercise_detail"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Exercise Card with Image -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardDetailImage"
            android:layout_width="0dp"
            android:layout_height="220dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvDetailTitle">

            <ImageView
                android:id="@+id/ivDetailImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_background"
                android:contentDescription="@string/exercise_name" />
        </androidx.cardview.widget.CardView>

        <!-- Exercise Name -->
        <TextView
            android:id="@+id/tvDetailName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Exercise Name"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardDetailImage" />

        <!-- Muscle Group Info -->
        <LinearLayout
            android:id="@+id/layoutMuscle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvDetailName">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/muscle_group"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/lime_accent"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/tvDetailCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Chest"
                android:textSize="15sp"
                android:textColor="?attr/colorOnSurface" />
        </LinearLayout>

        <!-- Description Info -->
        <LinearLayout
            android:id="@+id/layoutDesc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutMuscle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/description"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/lime_accent"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/tvDetailDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Exercise description goes here..."
                android:textSize="15sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- Implicit Intent buttons -->
        <LinearLayout
            android:id="@+id/layoutActions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutDesc">

            <!-- Watch Tutorial -->
            <Button
                android:id="@+id/btnWatchTutorial"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:backgroundTint="?attr/colorSurface"
                android:textColor="?attr/colorOnSurface"
                android:text="@string/watch_tutorial"
                android:textSize="15sp"
                android:textStyle="bold"
                android:drawableStart="@android:drawable/ic_menu_slideshow"
                android:drawablePadding="8dp"
                android:paddingHorizontal="16dp"
                android:gravity="start|center_vertical" />

            <!-- Find Nearby Gym -->
            <Button
                android:id="@+id/btnFindGym"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="?attr/colorSurface"
                android:textColor="?attr/colorOnSurface"
                android:text="@string/find_gym"
                android:textSize="15sp"
                android:textStyle="bold"
                android:drawableStart="@android:drawable/ic_dialog_map"
                android:drawablePadding="8dp"
                android:paddingHorizontal="16dp"
                android:gravity="start|center_vertical" />

            <!-- Share Exercise -->
            <Button
                android:id="@+id/btnShareExercise"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/lime_accent"
                android:textColor="@color/lime_on_accent"
                android:text="@string/share_exercise"
                android:textSize="15sp"
                android:textStyle="bold"
                android:drawableStart="@android:drawable/ic_menu_share"
                android:drawablePadding="8dp"
                android:paddingHorizontal="16dp"
                android:gravity="start|center_vertical" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
